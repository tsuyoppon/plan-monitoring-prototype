// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Initiative {
  id           Int       @id @default(autoincrement())
  domain       String
  measureName  String
  isActive     Boolean   @default(true)
  detail       String?
  goal         String?
  kpi          String?
  startDate    DateTime?
  endDate      DateTime?
  department   String?
  scheduleText String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  progressLogs ProgressLog[]
  reminderEmailLogs ReminderEmailLog[]

  @@map("initiatives")
}

model ProgressLog {
  id                Int       @id @default(autoincrement())
  initiativeId      Int
  fiscalYear        Int
  fiscalQuarter     Int
  progressStatus    String?
  progressEvaluation String?
  nextAction        String?
  inputBy           String?
  inputAt           DateTime?
  versionNo         Int       @default(1)
  isLatest          Boolean   @default(true)
  createdAt         DateTime  @default(now())

  initiative        Initiative @relation(fields: [initiativeId], references: [id])

  @@map("progress_logs")
}

model AppUser {
  id          Int     @id @default(autoincrement())
  email       String  @unique
  passwordHash String?
  displayName String?
  department  String?
  role        String  @default("editor")
  isActive    Boolean @default(true)

  receivedReminderEmailLogs ReminderEmailLog[] @relation("ReminderRecipient")
  sentReminderEmailLogs     ReminderEmailLog[] @relation("ReminderSender")

  @@map("app_users")
}

model ReminderEmailSetting {
  id          Int      @id @default(autoincrement())
  introText   String   @db.Text
  closingText String   @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("reminder_email_settings")
}

model ReminderEmailLog {
  id             Int      @id @default(autoincrement())
  userId         Int
  initiativeId   Int
  recipientEmail String
  recipientName  String
  subject        String
  body           String   @db.Text
  sentByUserId   Int?
  status         String   @default("sent")
  provider       String?
  providerMessageId String?
  errorMessage   String?  @db.Text
  sentAt         DateTime @default(now())

  user       AppUser    @relation("ReminderRecipient", fields: [userId], references: [id])
  initiative Initiative @relation(fields: [initiativeId], references: [id])
  sentBy     AppUser?   @relation("ReminderSender", fields: [sentByUserId], references: [id])

  @@map("reminder_email_logs")
}
